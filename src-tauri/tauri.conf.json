{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PaddleDesk",
  "version": "0.1.0",
  "identifier": "cc.ccwu.paddledesk",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PaddleDesk",
        "width": 1280,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 660,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost ws://127.0.0.1:1420; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIxOEJDOEQ1OUYyQ0YzM0QKUldROTh5eWYxY2lMc1ZsVVJpZkJYaFppT092NEl2c2kxbG9PMkwzRnhFZFRrS1ZweVlaakhxWS8K",
      "endpoints": [
        "https://github.com/chengbuilds/PaddleDesk/releases/latest/download/latest.json"
      ]
    }
  }
}
