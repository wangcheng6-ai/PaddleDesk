{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PaddleDesk",
  "version": "0.1.0",
  "identifier": "cc.ccwu.paddledesk",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PaddleDesk",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk0QTNBMTI5MjM0OUQyMEQKUldRTjBra2pLYUdqbElOVjkzVEFiQnJVS09DOGJsdFFyaE9BMXdCTGYwMjFaQ0k4Ti9MSGIwUzYK",
      "endpoints": [
        "https://github.com/wangcheng6-ai/PaddleDesk/releases/latest/download/latest.json"
      ]
    }
  }
}
